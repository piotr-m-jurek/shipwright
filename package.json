{
  "name": "shipwright",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names api,web --prefix-colors cyan,green \"tsx --watch src/server/server.ts\" \"vite\"",
    "dev:api": "tsx --watch src/server.ts",
    "dev:web": "vite",
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint -c oxlint.config.js",
    "lint:fix": "oxlint --fix",
    "docs:effect-update": "git subtree pull --prefix docs/effect-smol effect-smol main --squash"
  }
}
