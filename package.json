{
  "name": "shipwright",
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "dev": "concurrently --names api,web --prefix-colors cyan,green \"tsx --watch src/server.ts\" \"vite\"",
    "dev:api": "tsx --watch src/server.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node src/server.js",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint -c oxlint.config.js",
    "lint:fix": "oxlint --fix",
    "test": "vitest",
    "test:corpus": "tsx src/agent/test-corpus.ts",
    "docs:effect-update": "git subtree pull --prefix docs/effect-smol effect-smol main --squash"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.80",
    "@ai-sdk/openai": "3.0.66",
    "@aws-sdk/client-s3": "3.1055.0",
    "@aws-sdk/s3-request-presigner": "3.1057.0",
    "@effect/platform-node": "4.0.0-beta.83",
    "@mpsuesser/oxlint-plugin-effect": "^0.3.0",
    "ai": "6.0.191",
    "concurrently": "^10.0.3",
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-beta.22",
    "effect": "4.0.0-beta.83",
    "file-type": "22.0.1",
    "install": "^0.13.0",
    "js-tiktoken": "1.0.21",
    "lodash": "4.18.1",
    "mammoth": "1.12.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "ts-pattern": "5.9.0",
    "unpdf": "1.6.2",
    "vite": "8.0.14",
    "xstate": "5.32.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@types/bun": "latest",
    "@types/lodash": "4.17.24",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "1.0.0-beta.22",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "postgres": "3.4.9",
    "tsx": "4.22.3",
    "typescript": "~5.8.3",
    "vitest": "4.1.8"
  }
}
